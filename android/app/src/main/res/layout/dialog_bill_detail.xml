<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_glass_dialog">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="账单详情"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#333333"
        android:layout_marginBottom="16dp" />

    <!-- 金额 -->
    <TextView
        android:id="@+id/detail_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¥0"
        android:textSize="36sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- 信息卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/bg_glass_card">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                android:text="分类" android:textSize="13sp" android:textColor="#999" />
            <TextView android:id="@+id/detail_category" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="14sp" android:textColor="#333" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/glass_divider" android:layout_marginVertical="4dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                android:text="描述" android:textSize="13sp" android:textColor="#999" />
            <TextView android:id="@+id/detail_description" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="14sp" android:textColor="#333" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/glass_divider" android:layout_marginVertical="4dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                android:text="日期" android:textSize="13sp" android:textColor="#999" />
            <TextView android:id="@+id/detail_date" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="14sp" android:textColor="#333" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/glass_divider" android:layout_marginVertical="4dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                android:text="时间" android:textSize="13sp" android:textColor="#999" />
            <TextView android:id="@+id/detail_time" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="14sp" android:textColor="#333" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/glass_divider" android:layout_marginVertical="4dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                android:text="类型" android:textSize="13sp" android:textColor="#999" />
            <TextView android:id="@+id/detail_direction" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="14sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/glass_divider" android:layout_marginVertical="4dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp"
            android:id="@+id/detail_consumption_row">
            <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                android:text="消费类型" android:textSize="13sp" android:textColor="#999" />
            <TextView android:id="@+id/detail_consumption_type" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="14sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/glass_divider" android:layout_marginVertical="4dp"
            android:id="@+id/divider_consumption" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                android:text="支付方式" android:textSize="13sp" android:textColor="#999" />
            <TextView android:id="@+id/detail_payment" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="14sp" android:textColor="#333" />
        </LinearLayout>
    </LinearLayout>

    <!-- 操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/btn_detail_edit"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:text="编辑"
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:background="@drawable/bg_glass_button" />

        <TextView
            android:id="@+id/btn_detail_delete"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="删除"
            android:textSize="14sp"
            android:textColor="#F44336"
            android:background="@drawable/bg_glass_button" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_detail_close"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="关闭"
        android:textSize="14sp"
        android:textColor="#666666"
        android:background="@drawable/bg_glass_button" />

</LinearLayout>
