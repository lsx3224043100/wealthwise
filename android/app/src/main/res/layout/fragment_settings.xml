<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 用户信息卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:background="@drawable/bg_glass_card"
            android:elevation="2dp"
            android:layout_marginBottom="12dp">

            <!-- 头像圆形 -->
            <View
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_glass_button"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_user_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用户名: 未登录"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- 分类管理卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_glass_card"
            android:elevation="2dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="分类管理"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp" />

            <!-- 方向切换 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/btn_cat_expense"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="支出"
                    android:textSize="13sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_glass_button"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_cat_income"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="收入"
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:background="@drawable/bg_glass_button"
                    android:layout_marginStart="4dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- 添加分类 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/et_new_category"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:hint="新分类名称"
                    android:textSize="13sp"
                    android:background="@drawable/bg_glass_button"
                    android:paddingHorizontal="8dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/btn_add_category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="添加"
                    android:textSize="13sp"
                    android:textColor="@color/colorPrimary"
                    android:background="@drawable/bg_glass_button"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="点击分类可删除"
                android:textSize="12sp"
                android:textColor="#BBBBBB"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_category_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="加载中..."
                android:textSize="14sp"
                android:textColor="#666666"
                android:padding="4dp"
                android:lineSpacingExtra="6dp" />
        </LinearLayout>

        <!-- 支付方式管理卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_glass_card"
            android:elevation="2dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="支付方式管理"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp" />

            <!-- 方向切换 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/btn_pay_expense"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="支出"
                    android:textSize="13sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_glass_button"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_pay_income"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="收入"
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:background="@drawable/bg_glass_button"
                    android:layout_marginStart="4dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/et_new_payment"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:hint="新支付方式"
                    android:textSize="13sp"
                    android:background="@drawable/bg_glass_button"
                    android:paddingHorizontal="8dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/btn_add_payment"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="添加"
                    android:textSize="13sp"
                    android:textColor="@color/colorPrimary"
                    android:background="@drawable/bg_glass_button"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="点击可删除"
                android:textSize="12sp"
                android:textColor="#BBBBBB"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_payment_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="微信  支付宝  现金  银行卡"
                android:textSize="14sp"
                android:textColor="#666666"
                android:padding="4dp"
                android:lineSpacingExtra="6dp" />
        </LinearLayout>

        <!-- 退出登录 -->
        <TextView
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="退出登录"
            android:textSize="14sp"
            android:textColor="#F44336"
            android:background="@drawable/bg_glass_button"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
