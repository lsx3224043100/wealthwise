<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- 玻璃态顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@drawable/bg_glass_card"
        android:elevation="2dp">

        <!-- 收入/支出切换（带图标） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/btn_toggle_expense"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="↓ 支出"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_glass_button"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_toggle_income"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="↑ 收入"
                android:textSize="14sp"
                android:textColor="#999999"
                android:background="@drawable/bg_glass_button"
                android:layout_marginStart="4dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 芯片筛选 -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true"
            app:singleSelection="true"
            app:chipSpacing="6dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="全部"
                android:textSize="13sp" android:textStyle="bold"
                android:checked="true"
                app:chipBackgroundColor="@color/chip_color_selector"
                    app:chipStrokeColor="@color/chip_stroke_color_selector" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_day"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="日"
                android:textSize="13sp" android:textStyle="bold"
                app:chipBackgroundColor="@color/chip_color_selector"
                    app:chipStrokeColor="@color/chip_stroke_color_selector" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_month"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="月"
                android:textSize="13sp" android:textStyle="bold"
                app:chipBackgroundColor="@color/chip_color_selector"
                    app:chipStrokeColor="@color/chip_stroke_color_selector" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_year"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="年"
                android:textSize="13sp" android:textStyle="bold"
                app:chipBackgroundColor="@color/chip_color_selector"
                    app:chipStrokeColor="@color/chip_stroke_color_selector" />
        </com.google.android.material.chip.ChipGroup>

        <!-- 日期导航行 -->
        <LinearLayout
            android:id="@+id/layout_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btn_prev"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="◀"
                android:textSize="16sp"
                android:textColor="#666666"
                android:background="@drawable/bg_glass_button"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tv_current_period"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:paddingHorizontal="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_glass_button"
                android:layout_marginHorizontal="6dp" />

            <TextView
                android:id="@+id/btn_next"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="▶"
                android:textSize="16sp"
                android:textColor="#666666"
                android:background="@drawable/bg_glass_button"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </LinearLayout>

    <!-- 饼图（玻璃态卡片） -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        android:background="@drawable/bg_glass_card"
        android:elevation="2dp">

        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChart"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- 底部统计（玻璃态卡片） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_glass_card"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tv_stat_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="分类统计"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_total_expense"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="总支出: ¥0.00"
                android:textSize="15sp"
                android:textColor="#4CAF50" />

            <TextView
                android:id="@+id/tv_total_income"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="总收入: ¥0.00"
                android:textSize="15sp"
                android:textColor="#F44336"
                android:gravity="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_tab_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp" android:textStyle="bold"
            android:textColor="#999999"
            android:layout_marginTop="4dp" />

        <!-- 消费类型占比（仅支出时显示） -->
        <LinearLayout
            android:id="@+id/layout_consumption_breakdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/glass_divider" android:layout_marginVertical="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="消费类型分布"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView android:id="@+id/tv_consume_normal"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="必要 0%"
                    android:textSize="12sp" android:textColor="#4CAF50" />

                <TextView android:id="@+id/tv_consume_optimizable"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="可省 0%"
                    android:textSize="12sp" android:textColor="#FF9800" />

                <TextView android:id="@+id/tv_consume_impulse"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="冲动 0%"
                    android:textSize="12sp" android:textColor="#F44336" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
